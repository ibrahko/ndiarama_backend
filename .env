# -------------------------------------------------
# Django / Projet
# -------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev

DEBUG=True

# Clé secrète Django (génère une vraie clé pour la prod)
SECRET_KEY=django-insecure-t4b6y0pa#a8y+f$%)_4y*@4qe6@x-+gm(so#f5f-_nqv%@2kq-

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1,nginx,web

# -------------------------------------------------
# Base de données
# -------------------------------------------------
# Utilisé par django-environ dans base.py
DATABASE_URL=postgres://ndiarama_user:ndiarama@db:5432/ndiarama

# Utilisé par le service Postgres dans docker-compose
POSTGRES_DB=ndiarama
POSTGRES_USER=ndiarama_user
POSTGRES_PASSWORD=ndiarama

# -------------------------------------------------
# CORS / CSRF
# -------------------------------------------------
# En dev tu peux laisser ALL_ORIGINS à True
CORS_ALLOW_ALL_ORIGINS=True

# Si tu veux restreindre, mets ALL_ORIGINS=False et configure CORS_ALLOWED_ORIGINS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Pour la prod, tu pourras ajouter ton domaine ici
CSRF_TRUSTED_ORIGINS=https://ndiarama.com,https://www.ndiarama.com

# -------------------------------------------------
# Email
# -------------------------------------------------
DEFAULT_FROM_EMAIL=no-reply@ndiarama.com
CONTACT_EMAIL=contact@ndiarama.com

# Backend SMTP (prod) – en dev, dev.py bascule en console backend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=user@example.com
EMAIL_HOST_PASSWORD=change_me_smtp_password
EMAIL_USE_TLS=True

# -------------------------------------------------
# Logging
# -------------------------------------------------
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=DEBUG

# -------------------------------------------------
# Sentry (erreurs / perf) – laisser vide si non utilisé
# -------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# -------------------------------------------------
# Sécurité prod (utilisé par prod.py)
# -------------------------------------------------
SECURE_HSTS_SECONDS=3600
SECURE_SSL_REDIRECT=False

# -------------------------------------------------
# Divers / future extensions
# -------------------------------------------------
# Exemple si tu ajoutes Redis, Celery, etc. plus tard
REDIS_URL=redis://redis:6379/0